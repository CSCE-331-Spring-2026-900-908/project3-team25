# Database (optional if you want CSV fallback only)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=team_25_db
DB_USER=postgres
DB_PASSWORD=your_database_password

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Optional but recommended for deployed environments like Render
GOOGLE_CALLBACK_URL=https://your-render-service.onrender.com/auth/google/callback

# Session security
SESSION_SECRET=replace_with_a_long_random_secret

# Comma-separated manager emails
MANAGER_EMAILS=manager1@tamu.edu,manager2@tamu.edu

# Optional AI settings
OPENAI_API_KEY=
OPENAI_MODEL=




LARA_ACCESS_KEY_ID=
LARA_ACCESS_KEY_SECRET=

#LARA_ACCESS_KEY_ID=your_access_key_id_here
#LARA_ACCESS_KEY_SECRET=your_access_key_secret_here


